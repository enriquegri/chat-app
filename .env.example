# Database
DB_HOST=mariadb
DB_PORT=3306
DB_USER=chatapp
DB_PASSWORD=change-this-password
DB_NAME=chatapp
DB_ROOT_PASSWORD=change-this-root-password

# Backend
APP_PORT=8080
JWT_SECRET=change-this-in-production-use-a-long-random-string
PUBLIC_URL=https://api.yourdomain.com
ALLOWED_ORIGINS=https://chat.yourdomain.com

# Encryption (required) — generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Registration
REGISTRATION_ENABLED=false

# LiveKit voice calls — generate keys with: openssl rand -hex 12 / openssl rand -hex 32
LIVEKIT_URL=wss://api.yourdomain.com/livekit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Web Push notifications (optional) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
